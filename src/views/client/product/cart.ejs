<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="utf-8">
    <title>Giỏ Hàng - Laptop Shop</title>
    <meta content="width=device-width, initial-scale=1.0" name="viewport">

    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;600;700&display=swap"
        rel="stylesheet">

    <link rel="stylesheet" href="https://use.fontawesome.com/releases/v5.15.4/css/all.css" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.4.1/font/bootstrap-icons.css" rel="stylesheet">

    <link href="/client/css/bootstrap.min.css" rel="stylesheet">
    <link href="/client/css/style.css" rel="stylesheet">

    <style>
        body {
            font-family: 'Plus Jakarta Sans', sans-serif;
            background-color: #f8f9fa;
        }

        /* Đẩy nội dung xuống dưới Header fixed-top (Topbar + Navbar) */
        .content-wrapper {
            padding-top: 160px;
            /* Cùng thông số với file Detail để đồng bộ */
        }

        @media (max-width: 992px) {
            .content-wrapper {
                padding-top: 100px;
            }
        }

        .cart-card {
            border: none;
            border-radius: 20px;
            box-shadow: 0 10px 30px rgba(0, 0, 0, 0.05);
            background-color: #fff;
        }

        .table thead th {
            background-color: #f8f9fa;
            border: none;
            padding: 20px;
            font-weight: 700;
            text-transform: uppercase;
            font-size: 0.85rem;
            letter-spacing: 1px;
        }

        .table tbody td {
            vertical-align: middle;
            padding: 20px;
            border-bottom: 1px solid #eee;
        }

        .product-img {
            width: 80px;
            height: 80px;
            object-fit: contain;
            background: #fff;
            padding: 5px;
            border: 1px solid #eee;
            border-radius: 12px;
        }

        .btn-quantity {
            width: 32px;
            height: 32px;
            display: flex;
            align-items: center;
            justify-content: center;
            border-radius: 8px !important;
            transition: all 0.2s;
        }

        .summary-card {
            background: #fff;
            border-radius: 20px;
            border: 1px solid #eee;
        }

        .btn-checkout {
            background-color: #81c408;
            /* Màu xanh chuẩn template */
            color: white;
            font-weight: 700;
            border-radius: 50px;
            padding: 15px;
            transition: all 0.3s;
        }

        .btn-checkout:hover {
            background-color: #6da306;
            color: white;
            transform: translateY(-2px);
            box-shadow: 0 5px 15px rgba(129, 196, 8, 0.3);
        }
    </style>
</head>

<body>
    <div id="spinner"
        class="show w-100 vh-100 bg-white position-fixed translate-middle top-50 start-50 d-flex align-items-center justify-content-center">
        <div class="spinner-grow text-primary" role="status"></div>
    </div>

    <%- include('../layout/header'); -%>

        <div class="content-wrapper">
            <div class="container pb-5">
                <nav aria-label="breadcrumb" class="mb-4">
                    <ol class="breadcrumb bg-white py-2 px-4 rounded-pill shadow-sm">
                        <li class="breadcrumb-item"><a href="/" class="text-decoration-none text-muted">Home</a></li>
                        <li class="breadcrumb-item active text-primary fw-bold" aria-current="page">Giỏ hàng của bạn
                        </li>
                    </ol>
                </nav>

                <div class="row g-4">
                    <div class="col-lg-8">
                        <div class="cart-card p-4">
                            <h4 class="fw-bold mb-4">Chi tiết đơn hàng</h4>
                            <div class="table-responsive">
                                <table class="table mb-0">
                                    <thead>
                                        <tr>
                                            <th scope="col">Sản phẩm</th>
                                            <th scope="col">Tên</th>
                                            <th scope="col">Giá</th>
                                            <th scope="col">Số lượng</th>
                                            <th scope="col">Tổng</th>
                                            <th scope="col">Xóa</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        <tr>
                                            <td>
                                                <img src="/client/img/vegetable-item-3.png" class="product-img"
                                                    alt="product">
                                            </td>
                                            <td>
                                                <p class="mb-0 fw-bold">Big Banana</p>
                                            </td>
                                            <td>
                                                <p class="mb-0">2.99 $</p>
                                            </td>
                                            <td>
                                                <div class="input-group" style="width: 110px;">
                                                    <button class="btn btn-sm btn-light border btn-quantity"><i
                                                            class="fa fa-minus"></i></button>
                                                    <input type="text"
                                                        class="form-control form-control-sm text-center border-0 fw-bold"
                                                        value="1">
                                                    <button class="btn btn-sm btn-light border btn-quantity"><i
                                                            class="fa fa-plus"></i></button>
                                                </div>
                                            </td>
                                            <td>
                                                <p class="mb-0 fw-bold">2.99 $</p>
                                            </td>
                                            <td>
                                                <button class="btn btn-sm text-danger bg-light rounded-circle">
                                                    <i class="fa fa-times"></i>
                                                </button>
                                            </td>
                                        </tr>
                                        <tr>
                                            <td>
                                                <img src="/client/img/vegetable-item-5.jpg" class="product-img"
                                                    alt="product">
                                            </td>
                                            <td>
                                                <p class="mb-0 fw-bold">Potatoes</p>
                                            </td>
                                            <td>
                                                <p class="mb-0">2.99 $</p>
                                            </td>
                                            <td>
                                                <div class="input-group" style="width: 110px;">
                                                    <button class="btn btn-sm btn-light border btn-quantity"><i
                                                            class="fa fa-minus"></i></button>
                                                    <input type="text"
                                                        class="form-control form-control-sm text-center border-0 fw-bold"
                                                        value="1">
                                                    <button class="btn btn-sm btn-light border btn-quantity"><i
                                                            class="fa fa-plus"></i></button>
                                                </div>
                                            </td>
                                            <td>
                                                <p class="mb-0 fw-bold">2.99 $</p>
                                            </td>
                                            <td>
                                                <button class="btn btn-sm text-danger bg-light rounded-circle">
                                                    <i class="fa fa-times"></i>
                                                </button>
                                            </td>
                                        </tr>
                                    </tbody>
                                </table>
                            </div>
                        </div>
                    </div>

                    <div class="col-lg-4">
                        <div class="summary-card p-4 shadow-sm">
                            <h4 class="fw-bold mb-4">Tổng cộng</h4>
                            <div class="d-flex justify-content-between mb-3">
                                <span class="text-muted">Tạm tính:</span>
                                <span class="fw-bold">$96.00</span>
                            </div>
                            <div class="d-flex justify-content-between mb-3 border-bottom pb-3">
                                <span class="text-muted">Phí vận chuyển:</span>
                                <span class="fw-bold">$3.00</span>
                            </div>
                            <div class="d-flex justify-content-between mb-4">
                                <h5 class="fw-bold">Thành tiền:</h5>
                                <h5 class="fw-bold text-danger">$99.00</h5>
                            </div>
                            <p class="small text-muted mb-4"><i class="fa fa-info-circle me-1"></i> Giao hàng tới
                                Ukraine.</p>
                            <button class="btn btn-checkout w-100 text-uppercase">
                                Tiến hành thanh toán
                            </button>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <%- include('../layout/footer'); -%>

            <script src="https://ajax.googleapis.com/ajax/libs/jquery/3.6.4/jquery.min.js"></script>
            <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.0.0/dist/js/bootstrap.bundle.min.js"></script>
            <script src="/client/js/main.js"></script>
</body>

</html>