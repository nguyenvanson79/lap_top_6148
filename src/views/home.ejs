<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>User List</title>

    <!-- Bootstrap -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">

    <style>
        body {
            background: linear-gradient(135deg, #eef2ff, #f8fafc);
        }

        .card {
            border-radius: 16px;
        }

        .table thead th {
            letter-spacing: 0.5px;
        }

        .table tbody tr:hover {
            transform: scale(1.01);
            transition: 0.2s ease;
        }

        .btn {
            border-radius: 10px;
        }
    </style>
</head>

<body>

    <!-- Navbar -->
    <nav class="navbar navbar-dark bg-primary shadow-sm">
        <div class="container-fluid px-4">
            <span class="navbar-brand mb-0 h4 fw-bold">User Management</span>
        </div>
    </nav>

    <div class="container mt-5">

        <!-- Header + Button -->
        <div class="d-flex justify-content-between align-items-center mb-4">
            <h2 class="fw-bold text-primary">📋 List Users</h2>
            <a href="/create-user" class="btn btn-success shadow-sm">
                + Create New User
            </a>
        </div>

        <!-- Card -->
        <div class="card shadow-lg border-0">
            <div class="card-body p-4">

                <!-- Table -->
                <div class="table-responsive">
                    <table class="table table-hover align-middle text-center">
                        <thead class="table-primary">
                            <tr>
                                <th>ID</th>
                                <th>NAME</th>
                                <th>EMAIL</th>
                                <th>ADDRESS</th>
                                <th>ACTION</th>
                            </tr>
                        </thead>

                        <tbody>
                            <% users.forEach( function (user) { %>

                                <tr>
                                    <td class="fw-semibold text-secondary">
                                        <%= user.id %>
                                    </td>
                                    <td class="fw-bold text-dark">
                                        <%= user.name %>
                                    </td>
                                    <td>
                                        <%= user.email %>
                                    </td>
                                    <td class="text-muted">
                                        <%= user.address %>
                                    </td>
                                    <td>
                                        <div class="d-flex justify-content-center gap-2">

                                            <form action="/edit-user/<%= user.id %>" method="get">
                                                <button class="btn btn-sm btn-warning shadow-sm">Edit</button>
                                            </form>


                                            <form action="/delete-user/<%= user.id %>" method="post">
                                                <button type="submit"
                                                    class="btn btn-sm btn-danger shadow-sm">Delete</button>
                                            </form>
                                        </div>
                                    </td>
                                </tr>

                                <% }) %>
                        </tbody>
                    </table>
                </div>

            </div>
        </div>

    </div>

</body>

</html>